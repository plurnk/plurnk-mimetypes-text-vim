{
    "name": "@plurnk/plurnk-mimetypes-text-vim",
    "version": "0.2.1",
    "description": "text/x-vim (Vimscript) mimetype handler for plurnk-service. Hand-rolled line scanner; no parser dependency.",
    "type": "module",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=26"
    },
    "plurnk": {
        "kind": "mimetype",
        "handlers": [
            {
                "name": "text/x-vim",
                "glyph": "📗",
                "extensions": [
                    ".vim",
                    ".vimrc",
                    ".gvimrc",
                    "vimrc",
                    "gvimrc",
                    "_vimrc",
                    "_gvimrc"
                ]
            }
        ]
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**/*",
        "README.md"
    ],
    "scripts": {
        "test:lint": "tsc --noEmit",
        "test:unit": "node --test src/**/*.test.ts",
        "test": "npm run test:lint && npm run test:unit",
        "build:dist": "tsc -p tsconfig.build.json",
        "build": "npm run build:dist",
        "prepare": "npm run build"
    },
    "devDependencies": {
        "@types/node": "^26.0.0",
        "typescript": "^6.0.3",
        "@plurnk/plurnk-mimetypes": "0.15.25"
    },
    "peerDependencies": {
        "@plurnk/plurnk-mimetypes": "^0.15.16"
    }
}
